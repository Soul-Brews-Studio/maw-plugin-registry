{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maw.soulbrews.studio/schema/plugin.json",
  "title": "maw plugin manifest",
  "description": "Per-plugin manifest (plugin.json at the root of a plugin repo).",
  "type": "object",
  "required": ["name", "version", "description", "author", "license", "sdk", "schemaVersion"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "minLength": 2,
      "maxLength": 64
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 4,
      "maxLength": 280
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "license": {
      "type": "string"
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "sdk": {
      "type": "string",
      "description": "Semver range of the maw-js plugin SDK the plugin targets."
    },
    "target": {
      "enum": ["js", "wasm"],
      "description": "Plugin compile target. Current registry plugins normally use js."
    },
    "entry": {
      "type": "string",
      "description": "Relative path to the plugin's entry module (e.g. ./index.ts)."
    },
    "weight": {
      "type": "integer",
      "minimum": 0,
      "description": "Dispatch/order weight; lower values run first."
    },
    "tier": {
      "enum": ["core", "standard", "extra"],
      "description": "Default install tier for maw-js plugin loading."
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "description": "Free-form capability strings the plugin advertises (e.g. \"attach:strategy\")."
    },
    "capabilityNamespaces": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "uniqueItems": true,
      "description": "Plugin-owned capability namespaces accepted for this manifest."
    },
    "cli": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "uniqueItems": true
        },
        "help": {
          "type": "string"
        },
        "flags": {
          "type": "object",
          "propertyNames": {
            "pattern": "^--[A-Za-z0-9][A-Za-z0-9-]*$"
          },
          "additionalProperties": {
            "enum": ["boolean", "string", "number"]
          }
        }
      }
    },
    "strategy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tier": { "type": "integer", "minimum": 1 }
      },
      "description": "Strategy-plugin metadata. `tier` selects which cascade tier this plugin implements."
    },
    "api": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^/[A-Za-z0-9_\\-/.]*$"
        },
        "methods": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
          }
        }
      }
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "serve": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "command": {
              "type": "string",
              "description": "Command a runner may use to start the persistent plugin process."
            },
            "prefix": {
              "type": "string",
              "pattern": "^/[A-Za-z0-9_\\-/.]*$",
              "description": "Gateway prefix the process registers, e.g. /api/fleet-ui."
            },
            "health": {
              "type": "string",
              "pattern": "^/[A-Za-z0-9_\\-/.]*$"
            },
            "events": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "eventPath": {
              "type": "string",
              "pattern": "^/[A-Za-z0-9_\\-/.]*$"
            }
          }
        }
      }
    },
    "schemaVersion": {
      "const": 1
    }
  }
}
